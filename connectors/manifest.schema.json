{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agennext.github.io/Agent-Identity/connectors/manifest.schema.json",
  "title": "Agent Identity Connector Manifest",
  "description": "Declarative manifest describing how an external system connects to the Agent Identity model. Each connector under connectors/*.connector.json conforms to this schema; scripts/validate_connectors.py enforces it in CI.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "provider", "category", "version", "auth", "capabilities", "mapping"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string" },
    "provider": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["idp", "iga", "pam", "saas", "runtime", "finance", "mcp", "scim"]
    },
    "version": { "type": "string" },
    "docs": { "type": "string", "format": "uri" },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["oauth2", "oidc", "api_key", "mtls", "jwt", "saml", "scim_token"]
        },
        "scopes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["provision", "deprovision", "verify", "revoke", "lifecycle_events",
                 "entitlements", "access_review", "attributes", "secrets", "sessions", "payments"]
      }
    },
    "endpoints": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["on", "action"],
        "properties": {
          "on": { "type": "string", "description": "Provider event name" },
          "action": {
            "type": "string",
            "description": "Agent Identity flow it maps to",
            "enum": ["provision", "activate", "revoke", "deprovision",
                     "verify", "update_entitlements", "open_review"]
          }
        }
      }
    },
    "mapping": {
      "type": "object",
      "description": "Provider concept -> Agent Identity model term.",
      "minProperties": 1,
      "additionalProperties": { "type": "string" }
    }
  }
}
